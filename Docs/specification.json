{
"ROLE": "Senior Full Stack Engineer",

"PROJECT_NAME": "KanbanFlow",

"PROJECT_DESCRIPTION": "A Trello-inspired Kanban project management platform. Users authenticate with email and password. After authentication, users can browse and edit all public projects and their own private projects. Users can create either public or private projects, create custom columns, create tasks, edit tasks, delete tasks, and drag tasks between columns.",

"TECH_STACK": {
"FRONTEND": {
"FRAMEWORK": "React",
"ROUTING": "React Router DOM",
"STYLING": "Tailwind CSS",
"UI_LIBRARY": "React Bits",
"DESIGN_REFERENCE": "21st.dev",
"DRAG_DROP": "dnd-kit",
"STATE_MANAGEMENT": "React Context + useState",
"HTTP_CLIENT": "Axios"
},

```
"BACKEND": {
  "RUNTIME": "Node.js",
  "FRAMEWORK": "Express.js",
  "AUTH": "JWT",
  "PASSWORD_HASHING": "bcrypt",
  "VALIDATION": "express-validator"
},

"DATABASE": {
  "TYPE": "PostgreSQL"
}
```

},

"DATABASE_SCHEMA": {
"users": {
"id": "SERIAL PRIMARY KEY",
"email": "VARCHAR(255) UNIQUE NOT NULL",
"password_hash": "TEXT NOT NULL",
"created_at": "TIMESTAMP DEFAULT NOW()"
},

```
"visibility_enum": [
  "public",
  "private"
],

"projects": {
  "id": "SERIAL PRIMARY KEY",
  "name": "VARCHAR(255) NOT NULL",
  "visibility": "visibility_enum NOT NULL",
  "owner_id": "INTEGER REFERENCES users(id)",
  "created_at": "TIMESTAMP DEFAULT NOW()"
},

"columns": {
  "id": "SERIAL PRIMARY KEY",
  "project_id": "INTEGER REFERENCES projects(id) ON DELETE CASCADE",
  "name": "VARCHAR(255) NOT NULL",
  "position": "INTEGER NOT NULL"
},

"tasks": {
  "id": "SERIAL PRIMARY KEY",
  "column_id": "INTEGER REFERENCES columns(id) ON DELETE CASCADE",
  "title": "VARCHAR(255) NOT NULL",
  "description": "TEXT",
  "due_date": "DATE",
  "position": "INTEGER NOT NULL",
  "created_at": "TIMESTAMP DEFAULT NOW()"
}
```

},

"AUTHENTICATION_FLOW": {
"SIGNUP": [
"User enters email",
"User enters password",
"Password hashed using bcrypt",
"User record created",
"JWT generated",
"JWT returned to frontend"
],

```
"LOGIN": [
  "User enters email",
  "User enters password",
  "Compare password with bcrypt",
  "Generate JWT",
  "Return JWT"
],

"JWT_PAYLOAD": {
  "userId": "INTEGER",
  "email": "STRING"
},

"FRONTEND_STORAGE": {
  "token": "localStorage"
}
```

},

