]
```

},

"API_ROUTES": {
"AUTH": [
"POST /auth/signup",
"POST /auth/login"
],

```
"PROJECTS": [
  "GET /projects",
  "GET /projects/:id",
  "POST /projects",
  "PUT /projects/:id",
  "DELETE /projects/:id"
],

"COLUMNS": [
  "POST /columns",
  "PUT /columns/:id",
  "DELETE /columns/:id"
],

"TASKS": [
  "POST /tasks",
  "PUT /tasks/:id",
  "DELETE /tasks/:id",
  "PUT /tasks/:id/move"
]
```

},

"GET_PROJECTS_LOGIC": {
"DESCRIPTION": "Return all public projects plus private projects owned by the current user",

```
"SQL": "SELECT * FROM projects WHERE visibility='public' OR owner_id=currentUserId"
```

},

"PROJECT_ACCESS_LOGIC": {
"DESCRIPTION": "Protect private projects from unauthorized access",

```
"RULE": "If project.visibility is private and project.owner_id does not equal req.user.id, return 403 Forbidden"
```

},

"SEARCH_FUNCTIONALITY": {
"LOCATION": "Dashboard",

```
"SEARCH_BY": [
  "Project Name"
],

"BEHAVIOR": "Real-time filtering"
```

},

